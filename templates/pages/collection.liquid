<!-- Collection/Category Page Template -->
<div class="collection-page">
    <div class="container">
        <!-- Collection Header -->
        <div class="collection-header">
            <div class="collection-breadcrumbs">
                <nav class="breadcrumbs" aria-label="Breadcrumb">
                    <ol class="breadcrumb-list">
                        <li class="breadcrumb-item">
                            <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a>
                        </li>
                        <li class="breadcrumb-item active">
                            {{ collection.title }}
                        </li>
                    </ol>
                </nav>
            </div>
            
            <div class="collection-info">
                <h1 class="collection-title">{{ collection.title }}</h1>
                {% if collection.description %}
                    <div class="collection-description">
                        {{ collection.description }}
                    </div>
                {% endif %}
                
                {% if collection.image %}
                    <div class="collection-image">
                        <img src="{{ collection.image | img_url: '1200x400' }}" 
                             alt="{{ collection.title }}"
                             loading="lazy">
                    </div>
                {% endif %}
            </div>
        </div>
        
        <!-- Collection Toolbar -->
        <div class="collection-toolbar">
            <div class="toolbar-left">
                <div class="product-count">
                    {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
                </div>
                
                <!-- Filter Toggle (Mobile) -->
                <button type="button" class="filter-toggle btn btn-outline" id="filter-toggle">
                    <svg viewBox="0 0 24 24" width="20" height="20">
                        <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" fill="currentColor"/>
                    </svg>
                    {{ 'collections.general.filters' | t }}
                </button>
            </div>
            
            <div class="toolbar-right">
                <!-- View Toggle -->
                <div class="view-toggle">
                    <button type="button" 
                            class="view-btn grid-view active" 
                            data-view="grid"
                            aria-label="Grid view">
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path d="M4 11h5V5H4v6zm0 7h5v-6H4v6zm6 0h5v-6h-5v6zm6 0h5v-6h-5v6zm-6-7h5V5h-5v6zm6-6v6h5V5h-5z" fill="currentColor"/>
                        </svg>
                    </button>
                    <button type="button" 
                            class="view-btn list-view" 
                            data-view="list"
                            aria-label="List view">
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path d="M4 14h4v-4H4v4zm0 5h4v-4H4v4zM4 9h4V5H4v4zm5 5h12v-4H9v4zm0 5h12v-4H9v4zM9 5v4h12V5H9z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                
                <!-- Sort Dropdown -->
                <div class="sort-dropdown">
                    <label for="sort-by" class="sr-only">{{ 'collections.general.sort_by' | t }}</label>
                    <select id="sort-by" class="sort-select">
                        <option value="manual">{{ 'collections.general.sort_by' | t }}: {{ 'collections.sorting.featured' | t }}</option>
                        <option value="best-selling">{{ 'collections.sorting.best_selling' | t }}</option>
                        <option value="title-ascending">{{ 'collections.sorting.title_ascending' | t }}</option>
                        <option value="title-descending">{{ 'collections.sorting.title_descending' | t }}</option>
                        <option value="price-ascending">{{ 'collections.sorting.price_ascending' | t }}</option>
                        <option value="price-descending">{{ 'collections.sorting.price_descending' | t }}</option>
                        <option value="created-ascending">{{ 'collections.sorting.date_ascending' | t }}</option>
                        <option value="created-descending">{{ 'collections.sorting.date_descending' | t }}</option>
                    </select>
                </div>
            </div>
        </div>
        
        <div class="collection-content">
            <!-- Sidebar Filters -->
            <aside class="collection-sidebar" id="collection-sidebar">
                <div class="sidebar-header">
                    <h3 class="sidebar-title">{{ 'collections.general.filters' | t }}</h3>
                    <button type="button" class="sidebar-close" id="sidebar-close">
                        <svg viewBox="0 0 24 24" width="24" height="24">
                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                
                <div class="sidebar-content">
                    <!-- Price Filter -->
                    <div class="filter-group">
                        <h4 class="filter-title">{{ 'collections.filters.price' | t }}</h4>
                        <div class="price-filter">
                            <div class="price-inputs">
                                <input type="number" 
                                       class="price-input" 
                                       placeholder="{{ 'collections.filters.price_from' | t }}"
                                       id="price-from">
                                <span class="price-separator">-</span>
                                <input type="number" 
                                       class="price-input" 
                                       placeholder="{{ 'collections.filters.price_to' | t }}"
                                       id="price-to">
                            </div>
                            <button type="button" class="btn btn-sm btn-outline apply-price-filter">
                                {{ 'collections.filters.apply' | t }}
                            </button>
                        </div>
                    </div>
                    
                    <!-- Brand Filter -->
                    {% assign vendors = collection.products | map: 'vendor' | uniq %}
                    {% if vendors.size > 1 %}
                        <div class="filter-group">
                            <h4 class="filter-title">{{ 'collections.filters.brand' | t }}</h4>
                            <div class="filter-options">
                                {% for vendor in vendors %}
                                    <label class="filter-option">
                                        <input type="checkbox" 
                                               name="vendor" 
                                               value="{{ vendor | handle }}"
                                               class="filter-checkbox">
                                        <span class="checkmark"></span>
                                        {{ vendor }}
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                    
                    <!-- Color Filter -->
                    {% assign colors = collection.products | map: 'options' | flatten | where: 'name', 'Color' | map: 'values' | flatten | uniq %}
                    {% if colors.size > 0 %}
                        <div class="filter-group">
                            <h4 class="filter-title">{{ 'collections.filters.color' | t }}</h4>
                            <div class="color-filter-options">
                                {% for color in colors %}
                                    <label class="color-filter-option">
                                        <input type="checkbox" 
                                               name="color" 
                                               value="{{ color | handle }}"
                                               class="filter-checkbox">
                                        <span class="color-swatch" 
                                              style="background-color: {{ color | downcase | replace: ' ', '' }}"
                                              title="{{ color }}"></span>
                                        <span class="color-name">{{ color }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                    
                    <!-- Size Filter -->
                    {% assign sizes = collection.products | map: 'options' | flatten | where: 'name', 'Size' | map: 'values' | flatten | uniq %}
                    {% if sizes.size > 0 %}
                        <div class="filter-group">
                            <h4 class="filter-title">{{ 'collections.filters.size' | t }}</h4>
                            <div class="size-filter-options">
                                {% for size in sizes %}
                                    <label class="size-filter-option">
                                        <input type="checkbox" 
                                               name="size" 
                                               value="{{ size | handle }}"
                                               class="filter-checkbox">
                                        <span class="size-label">{{ size }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                    
                    <!-- Availability Filter -->
                    <div class="filter-group">
                        <h4 class="filter-title">{{ 'collections.filters.availability' | t }}</h4>
                        <div class="filter-options">
                            <label class="filter-option">
                                <input type="checkbox" 
                                       name="availability" 
                                       value="in-stock"
                                       class="filter-checkbox">
                                <span class="checkmark"></span>
                                {{ 'collections.filters.in_stock' | t }}
                            </label>
                            <label class="filter-option">
                                <input type="checkbox" 
                                       name="availability" 
                                       value="out-of-stock"
                                       class="filter-checkbox">
                                <span class="checkmark"></span>
                                {{ 'collections.filters.out_of_stock' | t }}
                            </label>
                        </div>
                    </div>
                    
                    <!-- Clear Filters -->
                    <div class="filter-actions">
                        <button type="button" class="btn btn-outline clear-filters">
                            {{ 'collections.filters.clear_all' | t }}
                        </button>
                    </div>
                </div>
            </aside>
            
            <!-- Products Grid -->
            <main class="collection-main">
                {% if collection.products.size > 0 %}
                    <div class="products-container" data-view="grid">
                        <div class="products-grid" id="products-grid">
                            {% for product in collection.products %}
                                {% render 'product-card', product: product, show_quick_view: true %}
                            {% endfor %}
                        </div>
                    </div>
                    
                    <!-- Pagination -->
                    {% if paginate.pages > 1 %}
                        <nav class="pagination" aria-label="Pagination">
                            {% if paginate.previous %}
                                <a href="{{ paginate.previous.url }}" class="pagination-btn pagination-prev">
                                    <svg viewBox="0 0 24 24" width="20" height="20">
                                        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" fill="currentColor"/>
                                    </svg>
                                    {{ 'general.pagination.previous' | t }}
                                </a>
                            {% endif %}
                            
                            <div class="pagination-pages">
                                {% for part in paginate.parts %}
                                    {% if part.is_link %}
                                        <a href="{{ part.url }}" class="pagination-page">{{ part.title }}</a>
                                    {% else %}
                                        {% if part.title == paginate.current_page %}
                                            <span class="pagination-page current">{{ part.title }}</span>
                                        {% else %}
                                            <span class="pagination-page">{{ part.title }}</span>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                            
                            {% if paginate.next %}
                                <a href="{{ paginate.next.url }}" class="pagination-btn pagination-next">
                                    {{ 'general.pagination.next' | t }}
                                    <svg viewBox="0 0 24 24" width="20" height="20">
                                        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="currentColor"/>
                                    </svg>
                                </a>
                            {% endif %}
                        </nav>
                    {% endif %}
                {% else %}
                    <!-- Empty State -->
                    <div class="empty-collection">
                        <div class="empty-icon">
                            <svg viewBox="0 0 24 24" width="64" height="64">
                                <path d="M19 7h-3V6a4 4 0 0 0-8 0v1H5a1 1 0 0 0-1 1v11a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V8a1 1 0 0 0-1-1zM10 6a2 2 0 0 1 4 0v1h-4V6zm8 13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V9h2v1a1 1 0 0 0 2 0V9h4v1a1 1 0 0 0 2 0V9h2v10z" fill="currentColor"/>
                            </svg>
                        </div>
                        <h3 class="empty-title">{{ 'collections.general.no_products' | t }}</h3>
                        <p class="empty-description">{{ 'collections.general.no_products_description' | t }}</p>
                        <a href="{{ routes.collections_url }}" class="btn btn-primary">
                            {{ 'collections.general.browse_collections' | t }}
                        </a>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
</div>

<!-- Filter Overlay -->
<div class="filter-overlay" id="filter-overlay"></div>

<!-- Structured Data for Collection -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ collection.title | escape }}",
  "description": "{{ collection.description | strip_html | escape }}",
  "url": "{{ shop.url }}{{ collection.url }}",
  "numberOfItems": "{{ collection.products_count }}",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": "{{ collection.products_count }}",
    "itemListElement": [
      {% for product in collection.products limit: 10 %}
        {
          "@type": "Product",
          "position": {{ forloop.index }},
          "name": "{{ product.title | escape }}",
          "url": "{{ shop.url }}{{ product.url }}",
          "image": "{{ product.featured_image | img_url: '600x600' }}",
          "offers": {
            "@type": "Offer",
            "price": "{{ product.price | divided_by: 100.0 }}",
            "priceCurrency": "{{ shop.currency }}",
            "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
}
</script>